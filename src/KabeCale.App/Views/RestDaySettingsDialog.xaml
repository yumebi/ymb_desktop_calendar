<Window x:Class="KabeCale.App.Views.RestDaySettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="休日設定" Height="420" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource CalBackgroundBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0"
                    Background="{DynamicResource CalBackgroundBrush}"
                    BorderBrush="{DynamicResource CalGridLineBrush}">
            <TabItem Header="公休日">
                <StackPanel Margin="8">
                    <TextBlock Text="曜日×週を選んで公休日を指定します。" Margin="0,0,0,8" FontSize="11"
                               Foreground="{DynamicResource CalForegroundBrush}"/>
                    <Grid x:Name="PublicGrid"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="私休日">
                <StackPanel Margin="8">
                    <TextBlock Text="曜日×週を選んで私休日を指定します。" Margin="0,0,0,8" FontSize="11"
                               Foreground="{DynamicResource CalForegroundBrush}"/>
                    <Grid x:Name="PrivateGrid"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" Width="70" Margin="0,0,6,0" Click="OkButton_Click" IsDefault="True"/>
            <Button Content="キャンセル" Width="70" Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
