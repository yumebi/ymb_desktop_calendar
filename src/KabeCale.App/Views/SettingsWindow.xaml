<Window x:Class="KabeCale.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定" Height="660" Width="280"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource CalBackgroundBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="テーマ" Margin="0,0,0,4"
                   Foreground="{DynamicResource CalForegroundBrush}"/>
        <ComboBox x:Name="ThemeComboBox" Grid.Row="1" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="2" Text="表示月数" Margin="0,0,0,4"
                   Foreground="{DynamicResource CalForegroundBrush}"/>
        <ComboBox x:Name="MonthCountComboBox" Grid.Row="3" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="4" Text="並び方向" Margin="0,0,0,4"
                   Foreground="{DynamicResource CalForegroundBrush}"/>
        <ComboBox x:Name="LayoutDirectionComboBox" Grid.Row="5" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="6" Text="週の開始曜日" Margin="0,0,0,4"
                   Foreground="{DynamicResource CalForegroundBrush}"/>
        <ComboBox x:Name="FirstDayOfWeekComboBox" Grid.Row="7" Margin="0,0,0,10"/>

        <TextBlock Grid.Row="8" Text="文字サイズ" Margin="0,0,0,4"
                   Foreground="{DynamicResource CalForegroundBrush}"/>
        <ComboBox x:Name="FontScaleComboBox" Grid.Row="9" Margin="0,0,0,10"/>

        <Grid Grid.Row="10" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="背景の透明度"
                       Foreground="{DynamicResource CalForegroundBrush}"/>
            <TextBlock x:Name="BackgroundOpacityValueText" Grid.Column="1"
                       Foreground="{DynamicResource CalForegroundBrush}"/>
        </Grid>
        <Slider x:Name="BackgroundOpacitySlider" Grid.Row="11" Margin="0,0,0,10"
                Minimum="0.3" Maximum="1.0" SmallChange="0.05" LargeChange="0.1"
                TickFrequency="0.05" IsSnapToTickEnabled="True"
                ValueChanged="BackgroundOpacitySlider_ValueChanged"/>

        <CheckBox x:Name="ShowWeekNumbersCheckBox" Grid.Row="12" Content="週番号を表示する" Margin="0,0,0,8"
                  Foreground="{DynamicResource CalForegroundBrush}"/>
        <CheckBox x:Name="PinToDesktopCheckBox" Grid.Row="13" Content="デスクトップに常駐(壁紙化)" Margin="0,0,0,8"
                  Foreground="{DynamicResource CalForegroundBrush}"/>
        <CheckBox x:Name="ClickThroughCheckBox" Grid.Row="14" Content="クリックを透過させる" Margin="0,0,0,8"
                  Foreground="{DynamicResource CalForegroundBrush}"/>
        <CheckBox x:Name="LaunchAtStartupCheckBox" Grid.Row="15" Content="Windows起動時に自動起動" Margin="0,0,0,8"
                  Foreground="{DynamicResource CalForegroundBrush}"/>

        <StackPanel Grid.Row="16" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="エクスポート" Width="90" Margin="0,0,6,0" Click="ExportButton_Click"/>
            <Button Content="インポート" Width="90" Click="ImportButton_Click"/>
        </StackPanel>

        <Button x:Name="RestDaySettingsButton" Grid.Row="17" Content="休日設定..." Height="26"
                HorizontalAlignment="Stretch" VerticalAlignment="Top" Click="RestDaySettingsButton_Click"/>

        <Grid Grid.Row="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="VersionText" Grid.Column="0"
                       VerticalAlignment="Center" FontSize="10" Opacity="0.6"
                       Foreground="{DynamicResource CalForegroundBrush}"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" Width="70" Margin="0,0,6,0" Click="OkButton_Click" IsDefault="True"/>
                <Button Content="キャンセル" Width="70" Click="CancelButton_Click" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
