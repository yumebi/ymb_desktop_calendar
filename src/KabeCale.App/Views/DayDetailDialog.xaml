<Window x:Class="KabeCale.App.Views.DayDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="予定とメモ" Height="620" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource CalBackgroundBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="DateText" Grid.Row="0" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"
                   Foreground="{DynamicResource CalForegroundBrush}"/>

        <TextBlock Grid.Row="1" Text="メモ" Margin="0,0,0,4"
                   Foreground="{DynamicResource CalForegroundBrush}"/>
        <TextBox x:Name="MemoTextBox" Grid.Row="2" AcceptsReturn="True" TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"/>

        <Grid Grid.Row="3" Margin="0,10,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="予定" VerticalAlignment="Center"
                       Foreground="{DynamicResource CalForegroundBrush}"/>
            <Button x:Name="NewButton" Grid.Column="1" Content="新規" Width="56" Margin="0,0,6,0"
                    Click="NewButton_Click"/>
            <Button x:Name="DeleteButton" Grid.Column="2" Content="削除" Width="56"
                    Click="DeleteButton_Click"/>
        </Grid>
        <ListBox x:Name="EventListBox" Grid.Row="4" MinHeight="90"
                 SelectionChanged="EventListBox_SelectionChanged"/>

        <Border Grid.Row="5" Margin="0,10,0,0" Padding="8" CornerRadius="4"
                BorderThickness="1" BorderBrush="{DynamicResource CalGridLineBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="件名" VerticalAlignment="Center" Margin="0,0,8,6"
                           Foreground="{DynamicResource CalForegroundBrush}"/>
                <TextBox x:Name="TitleTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="時刻" VerticalAlignment="Center" Margin="0,0,8,6"
                           Foreground="{DynamicResource CalForegroundBrush}"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBox x:Name="TimeTextBox" Width="60"/>
                    <TextBlock Text="(例 9:00、空欄可)" FontSize="10" VerticalAlignment="Center" Margin="6,0,0,0"
                               Foreground="{DynamicResource CalForegroundBrush}" Opacity="0.7"/>
                </StackPanel>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="色" VerticalAlignment="Center" Margin="0,0,8,6"
                           Foreground="{DynamicResource CalForegroundBrush}"/>
                <ComboBox x:Name="ColorComboBox" Grid.Row="2" Grid.Column="1" Width="110"
                          HorizontalAlignment="Left" Margin="0,0,0,6"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="備考" VerticalAlignment="Top" Margin="0,2,8,6"
                           Foreground="{DynamicResource CalForegroundBrush}"/>
                <TextBox x:Name="NoteTextBox" Grid.Row="3" Grid.Column="1" Height="52" Margin="0,0,0,6"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                <Button x:Name="ApplyButton" Grid.Row="4" Grid.Column="1" Content="追加" Width="70"
                        HorizontalAlignment="Right" Click="ApplyButton_Click"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" Width="70" Margin="0,0,6,0" Click="OkButton_Click" IsDefault="True"/>
            <Button Content="キャンセル" Width="70" Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
